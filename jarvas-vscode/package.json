{
  "name": "jarvas-chat",
  "displayName": "Jarvas Chat",
  "version": "0.1.0",
  "engines": {"vscode": "^1.85.0"},
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {"command": "jarvas.openChat", "title": "Jarvas: Open Chat"}
    ],
    "statusBarItems": [
      {
        "id": "jarvasChat",
        "text": "$(robot) Jarvas",
        "tooltip": "Open Jarvas Chat",
        "command": "jarvas.openChat",
        "alignment": "right",
        "priority": 1000
      }
    ]
  }
}