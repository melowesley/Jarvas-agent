{
  "name": "jarvas-chat",
  "displayName": "Jarvas Chat",
  "publisher": "jarvas",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.115.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "jarvas.openChat",
        "title": "Jarvas: Open Chat"
      }
    ],
    "statusBarItems": [
      {
        "id": "jarvasChat",
        "text": "$(robot) Jarvas",
        "tooltip": "Open Jarvas Chat",
        "command": "jarvas.openChat",
        "alignment": "right",
        "priority": 1000
      }
    ]
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.115.0",
    "typescript": "^6.0.2"
  }
}
