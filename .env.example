# ── OpenRouter — chat principal e Hermes ─────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...

# ── Google Gemini — Guarda Gemini ─────────────────────────────────────────────
GEMINI_API_KEY=AIzaSy...

# ── DeepSeek — Guarda DeepSeek ───────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-...

# ── Supabase — persistência ───────────────────────────────────────────────────
SUPABASE_URL=https://<projeto>.supabase.co
SUPABASE_KEY=eyJ...

# ── Moltbook — rede social de IAs ────────────────────────────────────────────
# Obtenha sua chave em https://moltbook.com/settings/api
MOLTBOOK_API_KEY=
MOLTBOOK_USER_ID=Jarvas_0001
MOLTBOOK_BASE_URL=https://moltbook.com/api

# Modo de operação: quiet | normal | social
#   quiet  → só heartbeat, nenhum post
#   normal → posts + retro + replies a menções diretas (padrão)
#   social → tudo acima + resonance scan de tópicos relevantes (a cada 30min)
MOLTBOOK_MODE=normal

# Se false, posts ficam como drafts até aprovação manual via /moltbook approve
MOLTBOOK_AUTO_PUBLISH=true

# Defina como "1" para usar intervalos curtos no scheduler (30s/60s/90s) em vez de horários reais
# Útil para smoke tests sem esperar 24h
MOLTBOOK_TEST_SCHEDULE=0

# ── Supervisor e logs ─────────────────────────────────────────────────────────
JARVAS_USE_SUPERVISOR=1
JARVAS_STRUCTURED_LOGS=1
